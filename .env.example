# ─────────────────────────────────────────
# Base de datos
# ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/novelupdates_recommender

# ─────────────────────────────────────────
# NovelUpdates — cookie de sesión
# Cómo obtenerla:
#   1. Ir a novelupdates.com e iniciar sesión
#   2. Abrir DevTools (F12) → Application (Chrome) o Storage (Firefox)
#   3. Cookies → https://www.novelupdates.com
#   4. Copiar el VALOR de la cookie "wordpress_logged_in_..."
# ⚠️  La cookie expira si cerrás sesión — renovarla si el scraper falla con 403
# ─────────────────────────────────────────
NU_SESSION_COOKIE=wordpress_logged_in_xxxx=tu_valor_aqui

# ─────────────────────────────────────────
# Scraping
# ─────────────────────────────────────────
SCRAPE_DELAY_SECONDS=1.0
SCRAPE_MAX_RETRIES=3
CANDIDATE_PAGES=10

# ─────────────────────────────────────────
# Recomendador
# ─────────────────────────────────────────
TOP_N_RECOMMENDATIONS=20
CACHE_TTL_HOURS=24

# Pesos por lista (no modificar salvo que quieras ajustar el perfil)
WEIGHT_BEST_THE_BEST=3
WEIGHT_DEFAULT=1

# Listas a ignorar (separadas por coma)
IGNORED_LISTS=["Plan to Read","Dropped"]

# ─────────────────────────────────────────
# Logging
# ─────────────────────────────────────────
LOG_LEVEL=INFO
